# ─── Orion AI Environment Variables ───

# OpenAI API Key (required for agent service)
OPENAI_API_KEY=your-openai-api-key-here

# PostgreSQL
POSTGRES_DB=orion_db
POSTGRES_USER=orion
POSTGRES_PASSWORD=orion_secret

# Backend
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/orion_db
SPRING_DATASOURCE_USERNAME=orion
SPRING_DATASOURCE_PASSWORD=orion_secret
AGENT_SERVICE_URL=http://agent-service:8000

# Agent Service
DATABASE_URL=postgresql://orion:orion_secret@postgres:5432/orion_db
